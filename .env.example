# Required for GitHub API activities (issues, prs, reviews)
GITHUB_TOKEN=
GITHUB_OWNER=MasterJi27
GITHUB_REPO=expert-couscous

# Safe defaults
ACTIVITY_TYPE=commits
DRY_RUN=true
CONFIRM_LIVE=
MAX_PER_RUN=10
MAX_COMMIT_DATE=2026-03-18

# Activity counts
COMMIT_COUNT=3
ISSUE_COUNT=1
PR_COUNT=1
REVIEW_COUNT=1

# Base branch for PRs
GITHUB_BASE_BRANCH=main

# Labels and assignees (comma-separated)
ISSUE_LABELS=automation,activity
ISSUE_ASSIGNEES=
PR_LABELS=automation,activity
PR_ASSIGNEES=

# Optional template file paths
ISSUE_TEMPLATE_PATH=./.github/ISSUE_TEMPLATE.md
PR_TEMPLATE_PATH=./.github/PULL_REQUEST_TEMPLATE.md

# Cooldown controls (hours)
COOLDOWN_HOURS_DEFAULT=24
COOLDOWN_HOURS_COMMITS=24
COOLDOWN_HOURS_ISSUES=24
COOLDOWN_HOURS_PRS=24
COOLDOWN_HOURS_REVIEWS=24

# GitHub pacing and retry controls (milliseconds)
API_DELAY_MS_DEFAULT=1500
API_DELAY_MS_ISSUES=1500
API_DELAY_MS_PRS=2000
API_DELAY_MS_REVIEWS=1500
RETRY_MAX_ATTEMPTS=5
RETRY_BASE_DELAY_MS=5000
SECONDARY_RATE_LIMIT_DELAY_MS=60000

# Optional state file path for cooldown tracking
STATE_PATH=./.activity-state.json
